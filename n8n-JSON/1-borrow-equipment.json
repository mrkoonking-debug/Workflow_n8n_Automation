            {
              "id": "stock-check",
              "leftValue": "={{ $json['จำนวนคงเหลือ'] }}",
              "rightValue": "0",
              "operator": { "type": "number", "operation": "gt" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-stock",
      "name": "IF - ตรวจสอบสต็อก",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [910, 300]
    },
