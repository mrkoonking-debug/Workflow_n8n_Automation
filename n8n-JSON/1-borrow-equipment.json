            { "id": "name", "name": "name", "value": "={{ $json.body.name }}", "type": "string" },
            { "id": "email", "name": "email", "value": "={{ $json.body.email }}", "type": "string" },
            { "id": "faculty", "name": "faculty", "value": "={{ $json.body.faculty }}", "type": "string" },
            { "id": "returnDate", "name": "returnDate", "value": "={{ $json.body.returnDate }}", "type": "string" }
          ]
        }
      },
      "id": "edit-fields-borrow",
